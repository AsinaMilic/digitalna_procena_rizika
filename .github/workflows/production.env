# This file documents the environment variables needed in Azure App Service
# DO NOT put actual values here - configure them in Azure Portal

# Database Configuration
DB_NAME=digitalni_registar_procene_rizika
DB_USER=admin123@digitalni-registar-procene-rizika
DB_PASSWORD=[SET_IN_AZURE_PORTAL]
DB_HOST=digitalni-registar-procene-rizika.database.windows.net
DB_PORT=1433

# Application Configuration
JWT_SECRET=[GENERATE_SECURE_KEY_IN_AZURE]
NODE_ENV=production
WEBSITE_NODE_DEFAULT_VERSION=20-lts

# Optional
DEBUG=false
ALLOWED_HOSTS=digitalni-registar-rizika.azurewebsites.net