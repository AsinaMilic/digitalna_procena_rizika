generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "sqlserver"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model PravnoLice {
  id      Int             @id @default(autoincrement())
  naziv   String
  pib     String
  adresa  String?
  procene ProcenaRizika[]
}

model ProcenaRizika {
  id            Int             @id @default(autoincrement())
  pravnoLiceId  Int
  datum         DateTime        @default(now())
  status        String          @default("u_toku")
  pravnoLice    PravnoLice      @relation(fields: [pravnoLiceId], references: [id])
  unosi         UnosRizika[]
  riskSelections RiskSelection[]
  riskRegister  RiskRegister[]
}

model GrupaRizika {
  id       Int          @id @default(autoincrement())
  naziv    String
  redosled Int
  unosi    UnosRizika[]
}

model UnosRizika {
  id        Int           @id @default(autoincrement())
  procenaId Int
  grupaId   Int
  polje     String
  vrednost  String
  procena   ProcenaRizika @relation(fields: [procenaId], references: [id])
  grupa     GrupaRizika   @relation(fields: [grupaId], references: [id])
}

model RiskSelection {
  id          Int           @id @default(autoincrement())
  procenaId   Int
  riskId      String
  dangerLevel Int
  description String        @default("")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  procena     ProcenaRizika @relation(fields: [procenaId], references: [id])

  @@unique([procenaId, riskId])
}

model RiskRegister {
  id                  Int           @id @default(autoincrement())
  procenaId           Int
  riskId              String
  description         String
  dangerLevel         Int
  exposure            Int
  vulnerability       Int
  consequences        Int
  probability         Int
  riskLevel           Int
  category            String
  acceptability       String
  recommendedMeasures String
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  procena             ProcenaRizika @relation(fields: [procenaId], references: [id])

  @@unique([procenaId, riskId])
}
