# Debug i dozvoljeni hostovi
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,digitalni-registar-rizika.azurewebsites.net,*.azurewebsites.net

# ODBC-generic varijable (možda ne koriste direktno Prisma, ali mogu biti korisne)
DB_NAME=digitalni_registar_procene_rizika
DB_USER=admin123
DB_PASSWORD=Aleksa2000
DB_HOST=digitalni-registar-procene-rizika.database.windows.net
DB_PORT=1433

# Prisma konekcioni string za SQL Server (glavna baza)
DATABASE_URL="sqlserver://digitalni-registar-procene-rizika.database.windows.net:1433;database=digitalni_registar_procene_rizika;user=admin123@digitalni-registar-procene-rizika;password={Aleksa2000};encrypt=true;trustServerCertificate=false;hostNameInCertificate=*.database.windows.net;loginTimeout=30"

# Prisma konekcioni string za SHADOW bazu (shadow_digitalni_registar_procene_rizika)
SHADOW_DATABASE_URL="sqlserver://digitalni-registar-procene-rizika.database.windows.net:1433;database=shadow_digitalni_registar_procene_rizika;user=admin123@digitalni-registar-procene-rizika;password={Aleksa2000};encrypt=true;trustServerCertificate=false;hostNameInCertificate=*.database.windows.net;loginTimeout=30"
